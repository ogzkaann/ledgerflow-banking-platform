{
  "name": "@ledgerflow/operations-console",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "overrides": {
    "js-yaml": "4.3.0"
  },
  "scripts": {
    "dev": "vite",
    "generate:api": "openapi-typescript ../../contracts/openapi/account-service.yaml -o src/api/generated/account.ts && openapi-typescript ../../contracts/openapi/transfer-service.yaml -o src/api/generated/transfer.ts && openapi-typescript ../../contracts/openapi/notification-service.yaml -o src/api/generated/notification.ts",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "npm run generate:api && tsc -b",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "build": "npm run generate:api && tsc -b && vite build",
    "test:e2e": "playwright test --project=mocked",
    "test:e2e:real": "playwright test --project=real"
  },
  "dependencies": {
    "@tanstack/react-query": "5.101.4",
    "lucide-react": "1.26.0",
    "oidc-client-ts": "3.5.0",
    "openapi-fetch": "0.17.0",
    "react": "19.2.8",
    "react-dom": "19.2.8",
    "react-oidc-context": "3.3.1",
    "react-router-dom": "7.18.1"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "7.0.0",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/jest-axe": "3.5.9",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.4",
    "@vitest/coverage-v8": "4.1.10",
    "axe-core": "4.12.1",
    "eslint": "10.7.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "globals": "17.7.0",
    "jest-axe": "10.0.0",
    "jsdom": "29.1.1",
    "msw": "2.15.0",
    "openapi-typescript": "7.13.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.65.0",
    "vite": "8.1.5",
    "vitest": "4.1.10"
  }
}
