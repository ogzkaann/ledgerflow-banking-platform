# Safe local-only defaults used by compose.yaml for the Account Service database.
ACCOUNT_POSTGRES_DB=ledgerflow_account
ACCOUNT_POSTGRES_USER=ledgerflow
ACCOUNT_POSTGRES_PASSWORD=ledgerflow-local-only
ACCOUNT_POSTGRES_PORT=5432

# Optional Account Service overrides. These defaults match the Compose service.
ACCOUNT_DB_URL=jdbc:postgresql://localhost:5432/ledgerflow_account
ACCOUNT_DB_USERNAME=ledgerflow
ACCOUNT_DB_PASSWORD=ledgerflow-local-only

# Transfer Service owns an independent PostgreSQL database.
TRANSFER_POSTGRES_DB=ledgerflow_transfer
TRANSFER_POSTGRES_USER=ledgerflow_transfer
TRANSFER_POSTGRES_PASSWORD=ledgerflow-transfer-local-only
TRANSFER_POSTGRES_PORT=5433
TRANSFER_DB_URL=jdbc:postgresql://localhost:5433/ledgerflow_transfer
TRANSFER_DB_USERNAME=ledgerflow_transfer
TRANSFER_DB_PASSWORD=ledgerflow-transfer-local-only

# Redis accelerates Transfer Service idempotency but is never authoritative.
TRANSFER_REDIS_HOST=localhost
TRANSFER_REDIS_PORT=6379

# Risk Service owns a separate PostgreSQL database.
RISK_POSTGRES_DB=ledgerflow_risk
RISK_POSTGRES_USER=ledgerflow_risk
RISK_POSTGRES_PASSWORD=ledgerflow-risk-local-only
RISK_POSTGRES_PORT=5434
RISK_DB_URL=jdbc:postgresql://localhost:5434/ledgerflow_risk
RISK_DB_USERNAME=ledgerflow_risk
RISK_DB_PASSWORD=ledgerflow-risk-local-only
RISK_MAXIMUM_AMOUNT=5000.00
RISK_BLOCKED_MARKER=RISK-REJECT
RISK_RULE_VERSION=risk-rules-v1

# Notification Service owns a separate PostgreSQL database.
NOTIFICATION_POSTGRES_DB=ledgerflow_notification
NOTIFICATION_POSTGRES_USER=ledgerflow_notification
NOTIFICATION_POSTGRES_PASSWORD=ledgerflow-notification-local-only
NOTIFICATION_POSTGRES_PORT=5435
NOTIFICATION_DB_URL=jdbc:postgresql://localhost:5435/ledgerflow_notification
NOTIFICATION_DB_USERNAME=ledgerflow_notification
NOTIFICATION_DB_PASSWORD=ledgerflow-notification-local-only

# Single-node local/demo Kafka broker. Services use the same host bootstrap address.
KAFKA_PORT=9092
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Bounded transactional-outbox polling. Kafka acknowledgement applies to all producers.
ACCOUNT_OUTBOX_POLL_INTERVAL=500ms
ACCOUNT_OUTBOX_BATCH_SIZE=50
TRANSFER_OUTBOX_POLL_INTERVAL=500ms
TRANSFER_OUTBOX_BATCH_SIZE=50
RISK_OUTBOX_POLL_INTERVAL=500ms
RISK_OUTBOX_BATCH_SIZE=50
KAFKA_ACK_TIMEOUT=10s

# Keycloak is the local/demo OIDC provider. Replace every local-only value in a
# shared environment; no production credential belongs in this file.
KEYCLOAK_PORT=8090
KEYCLOAK_PUBLIC_URL=http://localhost:8090
KEYCLOAK_ADMIN_USERNAME=ledgerflow-admin
KEYCLOAK_ADMIN_PASSWORD=ledgerflow-admin-local-only
LEDGERFLOW_OPS_CLI_SECRET=ledgerflow-ops-local-only
LEDGERFLOW_OPERATOR_CLI_SECRET=ledgerflow-operator-local-only
LEDGERFLOW_AUDITOR_CLI_SECRET=ledgerflow-auditor-local-only
OIDC_ISSUER_URI=http://localhost:8090/realms/ledgerflow
OIDC_JWK_SET_URI=http://localhost:8090/realms/ledgerflow/protocol/openid-connect/certs
OIDC_AUDIENCE=ledgerflow-api

# Gateway CORS and Redis-backed rate limiting. Redis keys use a gateway-specific
# prefix and never contain transfer, correlation, account, or idempotency IDs.
GATEWAY_REDIS_HOST=localhost
GATEWAY_REDIS_PORT=6379
GATEWAY_CORS_ALLOWED_ORIGINS=http://localhost:5173
GENERAL_READ_RATE_PER_SECOND=20
GENERAL_READ_RATE_BURST=40
ACCOUNT_CREATE_RATE_PER_SECOND=2
ACCOUNT_CREATE_RATE_BURST=4
ACCOUNT_FUNDING_RATE_PER_SECOND=1
ACCOUNT_FUNDING_RATE_BURST=2
TRANSFER_CREATE_RATE_PER_SECOND=5
TRANSFER_CREATE_RATE_BURST=10

# Optional observability profile. Host applications are scraped through
# host.docker.internal and write ECS JSON files below LEDGERFLOW_LOG_DIR.
GATEWAY_PORT=8080
ACCOUNT_SERVICE_PORT=8081
TRANSFER_SERVICE_PORT=8082
RISK_SERVICE_PORT=8083
NOTIFICATION_SERVICE_PORT=8084
LEDGERFLOW_LOG_DIR=logs
LEDGERFLOW_ENVIRONMENT=local
PROMETHEUS_PORT=9091
PROMETHEUS_RETENTION=7d
GRAFANA_PORT=3000
GRAFANA_PUBLIC_URL=http://localhost:3000
GRAFANA_ADMIN_USER=ledgerflow-admin
GRAFANA_ADMIN_PASSWORD=ledgerflow-grafana-local-only
ELASTICSEARCH_PORT=9200
ELASTIC_PASSWORD=ledgerflow-elastic-local-only
KIBANA_PORT=5601
KIBANA_SYSTEM_PASSWORD=ledgerflow-kibana-local-only
LOGSTASH_API_PORT=9600
LOGSTASH_PASSWORD=ledgerflow-logstash-local-only
KIBANA_SECURITY_KEY=ledgerflow-kibana-security-key-local-only-32
KIBANA_SAVED_OBJECTS_KEY=ledgerflow-saved-objects-key-local-only-32
KIBANA_REPORTING_KEY=ledgerflow-reporting-key-local-only-32
