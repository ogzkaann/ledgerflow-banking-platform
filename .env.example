# Safe local-only defaults used by compose.yaml for the Account Service database.
ACCOUNT_POSTGRES_DB=ledgerflow_account
ACCOUNT_POSTGRES_USER=ledgerflow
ACCOUNT_POSTGRES_PASSWORD=ledgerflow-local-only
ACCOUNT_POSTGRES_PORT=5432

# Optional Account Service overrides. These defaults match the Compose service.
ACCOUNT_DB_URL=jdbc:postgresql://localhost:5432/ledgerflow_account
ACCOUNT_DB_USERNAME=ledgerflow
ACCOUNT_DB_PASSWORD=ledgerflow-local-only

# Transfer Service owns an independent PostgreSQL database.
TRANSFER_POSTGRES_DB=ledgerflow_transfer
TRANSFER_POSTGRES_USER=ledgerflow_transfer
TRANSFER_POSTGRES_PASSWORD=ledgerflow-transfer-local-only
TRANSFER_POSTGRES_PORT=5433
TRANSFER_DB_URL=jdbc:postgresql://localhost:5433/ledgerflow_transfer
TRANSFER_DB_USERNAME=ledgerflow_transfer
TRANSFER_DB_PASSWORD=ledgerflow-transfer-local-only

# Redis accelerates Transfer Service idempotency but is never authoritative.
TRANSFER_REDIS_HOST=localhost
TRANSFER_REDIS_PORT=6379
